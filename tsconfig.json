{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "allowJs": true,
    "checkJs": false,
    "types": ["node"],
    "paths": {
      "@/lib/*": ["./lib/*"],
      "@/agents/*": ["./lib/agents/*"],
      "@/graph/*": ["./lib/graph/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "lib/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "stancestream-frontend"
  ]
}
