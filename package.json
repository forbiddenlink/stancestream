{
  "name": "stancestream",
  "type": "module",
  "version": "1.0.0",
  "description": "Real-Time Multi-Agent AI Intelligence Platform - Enterprise-grade system showcasing Redis capabilities for intelligent applications",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=test mocha --require @babel/register tests/**/*.test.js --recursive --timeout 10000",
    "test:unit": "mocha tests/unit/**/*.test.js --timeout 5000",
    "test:integration": "mocha tests/integration/**/*.test.js --timeout 10000",
    "test:contracts": "mocha tests/integration/debate-lifecycle-contract.test.js --timeout 10000",
    "test:edge-cases": "node tests/advanced-edge-case-tests.js",
    "test:performance": "node tests/performance-profiler.js",
    "test:accessibility": "node tests/accessibility-ux-audit.js",
    "test:monitoring": "node tests/production-monitoring.js",
    "test:quick": "mocha tests/unit/**/*.test.js --timeout 5000",
    "test:comprehensive": "npm run test:unit && npm run test:integration && node tests/production-refinement-orchestrator.js",
    "test:coverage": "c8 mocha tests/**/*.test.js --timeout 10000",
    "test:load": "artillery run tests/load-test.yml",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node vectorsearch.js && node index.js && node addReformer.js",
    "frontend": "cd stancestream-frontend && pnpm dev",
    "build": "cd stancestream-frontend && pnpm build",
    "build:ts": "tsc",
    "build:ts:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@ai-sdk/google": "^3.0.81",
    "@langchain/core": ">=1.1.48",
    "@langchain/langgraph": "^1.3.7",
    "@langchain/openai": "^0.6.17",
    "@trigger.dev/sdk": "^4.4.6",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "langfuse": "^3.38.20",
    "morgan": "^1.11.0",
    "openai": "^5.10.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.36.17",
    "prom-client": "^15.1.0",
    "redis": "^5.12.1",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@trigger.dev/build": "^4.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.20",
    "artillery": "^2.0.32",
    "axios": "^1.17.0",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "sinon": "^19.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "js-yaml": ">=4.1.1",
      "qs": ">=6.15.2",
      "diff": ">=8.0.3",
      "form-data": ">=4.0.4",
      "brace-expansion": ">=1.1.12",
      "braces": ">=3.0.3",
      "cross-spawn": ">=7.0.5",
      "picomatch": "^4.0.4",
      "flatted": ">=3.4.2",
      "minimatch": ">=10.2.3",
