      "rollup": ">=4.59.0",
      "socket.io-parser": ">=4.2.6",
      "express>path-to-regexp": "^0.1.13",
      "path-to-regexp": ">=8.3.0",
      "vite": ">=7.3.2",
      "lodash": "^4.18.1",
      "cookie": ">=0.7.0",
      "systeminformation": ">=5.31.6",
      "defu": ">=6.1.5",
      "yaml": ">=2.8.3",
      "next": ">=16.2.3",
      "protobufjs": "^7.6.1",
      "dompurify": ">=3.4.0",
      "uuid": ">=14.0.0",
      "@protobufjs/utf8": ">=1.1.1",
      "basic-ftp": ">=5.3.1",
      "ip-address": ">=10.1.1",
      "fast-xml-builder": ">=1.1.7",
      "postcss": ">=8.5.14",
      "shell-quote": ">=1.8.4",
      "esbuild": ">=0.28.1"
    }
